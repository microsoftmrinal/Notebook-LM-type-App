# Azure OpenAI Configuration
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Azure Cosmos DB Configuration
COSMOS_DB_ENDPOINT=https://your-cosmosdb.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-db-key-here

# Azure AI Foundry — Claude (optional, from AI Foundry portal)
# AZURE_CLAUDE_ENDPOINT=https://your-claude-endpoint.eastus2.models.ai.azure.com
# AZURE_CLAUDE_KEY=your-claude-endpoint-key

# Default model: "gpt" or "claude"
DEFAULT_MODEL=gpt
